<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

   <extension
         point="org.eclipse.ui.commands">
      <command
            id="eclipse.quick.generate.command"
            name="Quick Generate"
            description="Abre o menu de geração de código">
      </command>
   </extension>

   <extension
         point="org.eclipse.ui.bindings">
      <key
            commandId="eclipse.quick.generate.command"
            schemeId="org.eclipse.ui.defaultAcceleratorConfiguration"
            sequence="M1+M2+M3+N">
      </key>
   </extension>

   <extension
         point="org.eclipse.ui.handlers">
      <handler
            commandId="eclipse.quick.generate.command"
            class="eclipsequickgenerate.QuickGenerateCommand">
      </handler>
   </extension>

</plugin>